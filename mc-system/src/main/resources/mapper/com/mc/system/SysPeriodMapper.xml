<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.mc.system.mapper.SysPeriodMapper">

    <select id="selectByYear" resultType="com.mc.system.entity.SysPeriod">
        SELECT * FROM sys_period WHERE year = #{year} ORDER BY month
    </select>

    <select id="selectCurrent" resultType="com.mc.system.entity.SysPeriod">
        SELECT * FROM sys_period WHERE is_current = 1 LIMIT 1
    </select>

    <select id="selectByCode" resultType="com.mc.system.entity.SysPeriod">
        SELECT * FROM sys_period WHERE code = #{code}
    </select>

</mapper>