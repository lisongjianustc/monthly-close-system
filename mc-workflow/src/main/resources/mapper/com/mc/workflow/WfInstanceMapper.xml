<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.mc.workflow.mapper.WfInstanceMapper">

    <select id="selectByPeriodId" resultType="com.mc.workflow.entity.WfInstance">
        SELECT * FROM wf_instance
        WHERE period_id = #{periodId}
        ORDER BY start_time DESC
    </select>

    <select id="selectByUnitId" resultType="com.mc.workflow.entity.WfInstance">
        SELECT * FROM wf_instance
        WHERE unit_id = #{unitId}
        ORDER BY start_time DESC
    </select>

</mapper>
