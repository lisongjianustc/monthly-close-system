<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.mc.data.mapper.ImportBatchMapper">

    <select id="selectByBatchNo" resultType="com.mc.data.entity.ImportBatch">
        SELECT * FROM import_batch WHERE batch_no = #{batchNo}
    </select>

    <select id="selectByUserId" resultType="com.mc.data.entity.ImportBatch">
        SELECT * FROM import_batch WHERE import_user_id = #{userId} ORDER BY create_time DESC
    </select>

</mapper>
